# ============================================================
#  Contoso Travel Workshop — Environment Configuration
# ============================================================
#  QUICK START (recommended):
#    Run the setup script — it auto-discovers your Azure
#    resources and populates this file for you:
#
#      cd labs/notebooks
#      bash setup-env.sh
#
#  MANUAL SETUP:
#    1. Copy this file to .env in the SAME directory:
#         cp sample.env .env
#    2. Fill in the values below (see Lab 00 for where to
#       find each value in the Foundry portal)
#
#  The .env file is git-ignored and will NOT be committed.
# ============================================================


# ----------------------------------------------------------
#  AZURE_AI_PROJECT_ENDPOINT  (Required — All Labs)
# ----------------------------------------------------------
#  Full project endpoint URL for your Foundry project.
#  FORMAT: https://<account>.services.ai.azure.com/api/projects/<project>
#  FIND IT: Foundry Portal → Your Project → Overview → Project endpoint
# ----------------------------------------------------------
AZURE_AI_PROJECT_ENDPOINT=


# ----------------------------------------------------------
#  AZURE_AI_MODEL_DEPLOYMENT_NAME  (Required — All Labs)
# ----------------------------------------------------------
#  Name of the deployed model your agents will use.
#  RECOMMENDED: Deploy gpt-4.1-mini with ≥30K TPM quota.
#  FIND IT: Foundry Portal → Models + endpoints → Name column
# ----------------------------------------------------------
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1


# ----------------------------------------------------------
#  MODEL_ENDPOINT  (Required — Red Teaming labs)
# ----------------------------------------------------------
#  Base AI Services endpoint (WITHOUT /api/projects/...).
#  FORMAT: https://<account>.services.ai.azure.com
#  FIND IT: Foundry Portal → Models + endpoints → click deployment → Target URI
# ----------------------------------------------------------
MODEL_ENDPOINT=


# ----------------------------------------------------------
#  MODEL_API_KEY  (Required — Red Teaming labs)
# ----------------------------------------------------------
#  API key for your AI Services account.
#  ⚠️ SENSITIVE — never commit this to source control.
#  FIND IT: Foundry Portal → Models + endpoints → click deployment → Show key
# ----------------------------------------------------------
MODEL_API_KEY=


# ----------------------------------------------------------
#  TELEMETRY_CONNECTION_STRING  (Optional — Tracing labs)
# ----------------------------------------------------------
#  Application Insights connection string for tracing/telemetry.
#  The tracing labs can auto-discover this from your Foundry project,
#  but you can set it here as a manual override if needed.
#  FIND IT: Azure Portal → Application Insights → Overview → Connection String
# ----------------------------------------------------------
TELEMETRY_CONNECTION_STRING=


# ----------------------------------------------------------
#  AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED  (Recommended)
# ----------------------------------------------------------
#  When true, the Azure SDK records full prompt/completion content
#  in traces — essential for the observability labs.
# ----------------------------------------------------------
AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=true


# ----------------------------------------------------------
#  AZURE_LOG_LEVEL  (Optional)
# ----------------------------------------------------------
#  Reduces logging verbosity for Azure SDKs.
#  Set to "error" to suppress informational messages.
# ----------------------------------------------------------
AZURE_LOG_LEVEL=error


# ----------------------------------------------------------
#  AZURE_SUBSCRIPTION_ID  (Optional — used by setup-env.sh)
# ----------------------------------------------------------
#  Auto-populated by setup-env.sh from your active az login.
#  Only set manually if you have multiple subscriptions.
# ----------------------------------------------------------
AZURE_SUBSCRIPTION_ID=


# ----------------------------------------------------------
#  AZURE_RESOURCE_GROUP  (Optional — used by setup-env.sh)
# ----------------------------------------------------------
#  Auto-populated by setup-env.sh when it discovers your
#  Foundry project resources.
# ----------------------------------------------------------
AZURE_RESOURCE_GROUP=

